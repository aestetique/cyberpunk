{{!-- WEAPONS Block --}}
{{!-- Expects: weapons (array), showUnarmed (bool), and (when showUnarmed) unarmedDamage / unarmedTooltipFlavor / unarmedTooltipCalc --}}
<div class="section-block">
  <header class="tab-header">
    <span class="tab-title">WEAPONS</span>
    <img class="tab-badge" src="systems/cyberpunk/img/ui/badge-weapons.svg" alt="">
  </header>
  <div class="tab-content gear-content">
    {{#if showUnarmed}}
    {{!-- Unarmed Attack (always first) --}}
    <div class="gear-row" data-item-id="unarmed">
      <div class="gear-icon gear-fire-weapon" data-item-id="unarmed">
        <img src="systems/cyberpunk/img/ui/unarmed.svg" alt="{{loc "UnarmedAttack"}}">
      </div>
      <div class="gear-info gear-fire-weapon" data-item-id="unarmed">
        <span class="gear-name">{{loc "UnarmedAttack"}}</span>
        <span class="gear-context">Melee · 1 m</span>
      </div>
      <div class="gear-price invisible">
        <span class="price-value">0</span>
        <img src="systems/cyberpunk/img/ui/badge-eurodollar.svg" alt="eb">
      </div>
      <div class="gear-weight invisible">
        <span class="price-value">0</span>
        <img src="systems/cyberpunk/img/ui/badge-weight.svg" alt="kg">
      </div>
      <div class="gear-field unarmed-damage-tooltip" style="width: 60px;" data-tooltip-name="Unarmed Damage" data-flavor="{{unarmedTooltipFlavor}}" data-calc="{{unarmedTooltipCalc}}">
        <span class="field-top">{{unarmedDamage}}</span>
        <span class="field-bottom">Damage</span>
      </div>
      <div class="gear-field" style="width: 60px;"></div>
      <div class="gear-action-btn"></div>
      <div class="gear-actions"></div>
    </div>
    {{/if}}
    {{#each weapons as |weapon|}}
      <div class="gear-row weapon-row" data-item-id="{{weapon.id}}">
        <div class="gear-icon gear-fire-weapon" data-item-id="{{weapon.id}}">
          <img src="{{weapon.img}}" alt="{{weapon.name}}">
        </div>
        <div class="gear-info gear-fire-weapon" data-item-id="{{weapon.id}}">
          <span class="gear-name">{{weapon.name}}</span>
          <span class="gear-context">{{weapon.context}}</span>
        </div>
        <div class="gear-price">
          <span class="price-value">{{weapon.price}}</span>
          <img src="systems/cyberpunk/img/ui/badge-eurodollar.svg" alt="eb">
        </div>
        <div class="gear-weight">
          <span class="price-value">{{weapon.weight}}</span>
          <img src="systems/cyberpunk/img/ui/badge-weight.svg" alt="kg">
        </div>
        <div class="gear-field" style="width: 60px;">
          <span class="field-top">{{weapon.damage}}</span>
          <span class="field-bottom">Damage</span>
        </div>
        {{#if weapon.isRanged}}
          {{!-- Ranged: Magazine + Reload button --}}
          <div class="gear-field" style="width: 60px;">
            <span class="field-top">{{weapon.shotsLeft}} / {{weapon.shots}}</span>
            <span class="field-bottom">Magazine</span>
          </div>
          <div class="gear-action-btn reload-weapon" data-item-id="{{weapon.id}}" data-can-reload="{{weapon.canReload}}" title="{{#if weapon.canReload}}Reload{{else}}Magazine full or no ammo attached{{/if}}">
            <img src="systems/cyberpunk/img/ui/badge-reload{{#unless weapon.canReload}}-disabled{{/unless}}.svg" alt="Reload">
          </div>
        {{else if weapon.isExotic}}
          {{!-- Exotic: Charges + Charge button --}}
          <div class="gear-field" style="width: 60px;">
            <span class="field-top">{{weapon.chargesDisplay}}</span>
            <span class="field-bottom">Charges</span>
          </div>
          <div class="gear-action-btn charge-weapon" data-item-id="{{weapon.id}}" data-can-charge="{{weapon.canCharge}}" title="{{#if weapon.canCharge}}Recharge{{else}}Fully charged{{/if}}">
            <img src="systems/cyberpunk/img/ui/badge-charge{{#unless weapon.canCharge}}-disabled{{/unless}}.svg" alt="Charge">
          </div>
        {{else}}
          {{!-- Melee/Martial: empty field + empty action --}}
          <div class="gear-field" style="width: 60px;"></div>
          <div class="gear-action-btn"></div>
        {{/if}}
        <div class="gear-actions">
          <button class="gear-view" type="button" data-item-id="{{weapon.id}}" title="View">
            <img src="systems/cyberpunk/img/ui/icon-view.svg" alt="View">
          </button>
          <button class="gear-delete" type="button" data-item-id="{{weapon.id}}" title="Delete">
            <img src="systems/cyberpunk/img/ui/icon-trash.svg" alt="Delete">
          </button>
        </div>
      </div>

      {{!-- Attached ammo addon row (Ranged weapons only, when ammo attached) --}}
      {{#if weapon.hasAttachedAmmo}}
      <div class="gear-row weapon-row attached-ammo attached" data-item-id="{{weapon.attachedAmmoId}}" data-parent-id="{{weapon.id}}">
        <div class="option-icon detach-option gear-detach-ammo" data-item-id="{{weapon.id}}" title="{{loc "DetachAmmo"}}">
          <img src="systems/cyberpunk/img/ui/badge-option-on.svg" alt="Attached">
        </div>
        <div class="gear-icon">
          <img src="{{weapon.attachedAmmoImg}}" alt="{{weapon.attachedAmmoName}}">
        </div>
        <div class="gear-info">
          <span class="gear-name">{{weapon.attachedAmmoName}}</span>
          <span class="gear-context">{{weapon.attachedAmmoContext}}</span>
        </div>
        <div class="gear-price">
          <span class="price-value">{{weapon.attachedAmmoPrice}}</span>
          <img src="systems/cyberpunk/img/ui/badge-eurodollar.svg" alt="eb">
        </div>
        <div class="gear-weight">
          <span class="price-value">{{weapon.attachedAmmoWeight}}</span>
          <img src="systems/cyberpunk/img/ui/badge-weight.svg" alt="kg">
        </div>
        <div class="gear-field" style="width: 60px;">
          {{#if ../isUnlocked}}
            <input type="number" class="zone-input gear-quantity-input" data-item-id="{{weapon.attachedAmmoId}}" value="{{weapon.attachedAmmoQuantity}}" min="0">
          {{else}}
            <span class="zone-paired-readonly">{{weapon.attachedAmmoQuantity}}</span>
          {{/if}}
          <span class="field-bottom">In Pile</span>
        </div>
        <div class="gear-field" style="width: 60px;"></div>
        <div class="gear-action-btn"></div>
        <div class="gear-actions">
          <button class="gear-view" type="button" data-item-id="{{weapon.attachedAmmoId}}" title="View">
            <img src="systems/cyberpunk/img/ui/icon-view.svg" alt="View">
          </button>
        </div>
      </div>
      {{/if}}
    {{/each}}

    {{!-- Unattached ammo rows — sit at the bottom of the Weapons list with --}}
    {{!-- an inactive (detached) attach icon. Drag-drop attaches to a weapon. --}}
    {{#if unattachedAmmo.length}}
      <div class="detached-options-header">
        <span>AMMUNITION</span>
      </div>
    {{/if}}
    {{#each unattachedAmmo as |ammo|}}
      <div class="gear-row weapon-row attached-ammo detached" data-item-id="{{ammo.id}}" draggable="true">
        <div class="option-icon" title="{{loc "NoAmmoAttached"}}">
          <img src="systems/cyberpunk/img/ui/badge-option-off.svg" alt="Detached">
        </div>
        <div class="gear-icon">
          <img src="{{ammo.img}}" alt="{{ammo.name}}">
        </div>
        <div class="gear-info">
          <span class="gear-name">{{ammo.name}}</span>
          <span class="gear-context">{{ammo.context}}</span>
        </div>
        <div class="gear-price">
          <span class="price-value">{{ammo.totalPrice}}</span>
          <img src="systems/cyberpunk/img/ui/badge-eurodollar.svg" alt="eb">
        </div>
        <div class="gear-weight">
          <span class="price-value">{{ammo.weight}}</span>
          <img src="systems/cyberpunk/img/ui/badge-weight.svg" alt="kg">
        </div>
        <div class="gear-field" style="width: 60px;">
          {{#if ../isUnlocked}}
            <input type="number" class="zone-input gear-quantity-input" data-item-id="{{ammo.id}}" value="{{ammo.quantity}}" min="0">
          {{else}}
            <span class="zone-paired-readonly">{{ammo.quantity}}</span>
          {{/if}}
          <span class="field-bottom">Quantity</span>
        </div>
        <div class="gear-field" style="width: 60px;"></div>
        <div class="gear-action-btn"></div>
        <div class="gear-actions">
          <button class="gear-view" type="button" data-item-id="{{ammo.id}}" title="View">
            <img src="systems/cyberpunk/img/ui/icon-view.svg" alt="View">
          </button>
          <button class="gear-delete" type="button" data-item-id="{{ammo.id}}" title="Delete">
            <img src="systems/cyberpunk/img/ui/icon-trash.svg" alt="Delete">
          </button>
        </div>
      </div>
    {{/each}}
  </div>
</div>
