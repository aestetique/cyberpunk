<div class="fright-roll-wrapper">
  <header class="reload-header">
    <span class="reload-title">{{localize "CYBERPUNK.FrightRoll"}}</span>
    <a class="header-control close"><i class="fas fa-times"></i></a>
  </header>

  {{!-- Severity section bar --}}
  <div class="fire-mode-section">
    <img src="systems/cyberpunk/img/chat/stress.svg" alt="">
    <span class="fire-mode-label">{{localize "CYBERPUNK.Severity"}}</span>
  </div>

  {{!-- Difficulty number input --}}
  <div class="difficulty-input-wrap">
    <div class="number-input-controls" data-min="10" data-max="40" data-step="5">
      <button type="button" class="number-input-btn number-input-minus-btn">
        <img src="systems/cyberpunk/img/chat/minus.svg" alt="-">
      </button>
      <div class="number-input-display">
        <input type="text" inputmode="numeric" pattern="[0-9]*" maxlength="3" class="number-input-value" value="{{difficulty}}">
      </div>
      <button type="button" class="number-input-btn number-input-plus-btn">
        <img src="systems/cyberpunk/img/chat/plus.svg" alt="+">
      </button>
    </div>
  </div>

  {{!-- Familiarity section bar --}}
  <div class="fire-mode-section">
    <img src="systems/cyberpunk/img/chat/cool.svg" alt="">
    <span class="fire-mode-label">{{localize "CYBERPUNK.Familiarity"}}</span>
  </div>

  {{!-- Familiarity controls --}}
  <div class="luck-controls">
    <button type="button" class="luck-btn familiarity-minus-btn disabled">
      <img src="systems/cyberpunk/img/chat/minus-disabled.svg" alt="-">
    </button>
    <div class="luck-display">
      <span class="luck-value familiarity-value">0</span>
    </div>
    <button type="button" class="luck-btn familiarity-plus-btn">
      <img src="systems/cyberpunk/img/chat/plus.svg" alt="+">
    </button>
  </div>

  {{!-- Luck section bar --}}
  <div class="fire-mode-section">
    <img src="systems/cyberpunk/img/chat/luck.svg" alt="">
    <span class="fire-mode-label">{{localize "CYBERPUNK.LuckFull"}}</span>
  </div>

  {{!-- Luck controls --}}
  <div class="luck-controls{{#unless hasAnyLuck}} disabled{{/unless}}">
    <button type="button" class="luck-btn luck-minus-btn{{#unless canDecreaseLuck}} disabled{{/unless}}">
      <img src="systems/cyberpunk/img/chat/{{#if canDecreaseLuck}}minus{{else}}minus-disabled{{/if}}.svg" alt="-">
    </button>
    <div class="luck-display">
      <span class="luck-value">{{luckToSpend}}</span>
    </div>
    <button type="button" class="luck-btn luck-plus-btn{{#unless canIncreaseLuck}} disabled{{/unless}}">
      <img src="systems/cyberpunk/img/chat/{{#if canIncreaseLuck}}plus{{else}}plus-disabled{{/if}}.svg" alt="+">
    </button>
  </div>

  {{!-- Roll button --}}
  <button type="button" class="reload-apply-btn roll-btn">
    {{localize "CYBERPUNK.Roll"}}
  </button>
</div>
