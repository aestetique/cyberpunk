<div class="game-time-wrapper">
    <header class="reload-header">
        <span class="reload-title">{{localize "CYBERPUNK.GameTime"}}</span>
        <a class="header-control close" data-action="closeDialog"><i class="fas fa-times"></i></a>
    </header>

    {{!-- Current game date/time display --}}
    <div class="game-time-display">
        {{displayTime}}
    </div>

    {{!-- Adjustment controls: reuse luck-controls layout --}}
    <div class="luck-controls">
        <button type="button" class="luck-btn game-time-minus" data-action="timeMinus">
            <img src="systems/cyberpunk/img/chat/minus.svg" alt="-">
        </button>

        <div class="range-dropdown">
            <button type="button" class="range-dropdown-btn" data-action="toggleDropdown">
                <span class="range-label">{{selectedLabel}}</span>
                <i class="fas fa-chevron-down"></i>
            </button>
            <div class="range-dropdown-list">
                {{#each increments}}
                <div class="range-option{{#if selected}} selected{{/if}}" data-action="pickIncrement" data-index="{{index}}">
                    {{label}}
                </div>
                {{/each}}
            </div>
        </div>

        <button type="button" class="luck-btn game-time-plus" data-action="timePlus">
            <img src="systems/cyberpunk/img/chat/plus.svg" alt="+">
        </button>
    </div>
</div>
