{{!-- Details Tab --}}

{{!-- Row 1: Type + Has Slots / Takes Space --}}
<div class="variables-row">
  <div class="variable-field">
    <label class="variable-label">{{localize "CYBERPUNK.NetwareType"}}</label>
    {{#if isLocked}}
      <div class="dropdown">
        <span class="dropdown-text">{{selectedNetwareTypeLabel}}</span>
        <div class="dropdown-chevron">
          <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
        </div>
      </div>
    {{else}}
      <div class="dropdown-wrapper">
        <select class="dropdown-select" name="system.netwareType">
          {{#each netwareTypeOptions}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <div class="dropdown-chevron">
          <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
        </div>
      </div>
    {{/if}}
  </div>

  {{#if isCyberdeck}}
    <div class="variable-field">
      <label class="variable-label">{{localize "CYBERPUNK.HasSlots"}}</label>
      {{#if isLocked}}
        <div class="dropdown"><span class="dropdown-text">{{system.slots}}</span></div>
      {{else}}
        <input type="number" class="variable-input" name="system.slots" value="{{system.slots}}" min="0">
      {{/if}}
    </div>
  {{else}}
    <div class="variable-field">
      <label class="variable-label">{{localize "CYBERPUNK.TakesSpace"}}</label>
      {{#if isLocked}}
        <div class="dropdown"><span class="dropdown-text">{{system.takesSpace}}</span></div>
      {{else}}
        <input type="number" class="variable-input" name="system.takesSpace" value="{{system.takesSpace}}" min="0">
      {{/if}}
    </div>
  {{/if}}
</div>

{{!-- Upgrade-specific rows --}}
{{#if isUpgrade}}
  {{!-- Row 2: Effect (+ Value when Range) --}}
  <div class="variables-row">
    <div class="variable-field">
      <label class="variable-label">{{localize "CYBERPUNK.UpgradeEffect"}}</label>
      {{#if isLocked}}
        <div class="dropdown">
          <span class="dropdown-text">{{selectedUpgradeEffectLabel}}</span>
          <div class="dropdown-chevron">
            <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
          </div>
        </div>
      {{else}}
        <div class="dropdown-wrapper">
          <select class="dropdown-select" name="system.upgradeEffect">
            {{#each upgradeEffectOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
          <div class="dropdown-chevron">
            <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
          </div>
        </div>
      {{/if}}
    </div>

    {{#if isRangeUpgrade}}
      <div class="variable-field">
        <label class="variable-label">{{localize "CYBERPUNK.UpgradeValue"}}</label>
        {{#if isLocked}}
          <div class="dropdown"><span class="dropdown-text">{{system.upgradeValue}}</span></div>
        {{else}}
          <input type="number" class="variable-input" name="system.upgradeValue" value="{{system.upgradeValue}}" min="0">
        {{/if}}
      </div>
    {{/if}}
  </div>
{{/if}}

{{!-- Program-specific rows --}}
{{#if isProgram}}
  {{!-- Row 2: Subtype + REZ / ATK --}}
  <div class="variables-row">
    <div class="variable-field">
      <label class="variable-label">{{localize "CYBERPUNK.ProgramSubtype"}}</label>
      {{#if isLocked}}
        <div class="dropdown">
          <span class="dropdown-text">{{selectedProgramSubtypeLabel}}</span>
          <div class="dropdown-chevron">
            <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
          </div>
        </div>
      {{else}}
        <div class="dropdown-wrapper">
          <select class="dropdown-select" name="system.programSubtype">
            {{#each programSubtypeOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
          <div class="dropdown-chevron">
            <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
          </div>
        </div>
      {{/if}}
    </div>

    {{#if isAttacker}}
      <div class="variable-field">
        <label class="variable-label">{{localize "CYBERPUNK.ATK"}}</label>
        {{#if isLocked}}
          <div class="dropdown"><span class="dropdown-text">{{system.atk}}</span></div>
        {{else}}
          <input type="number" class="variable-input" name="system.atk" value="{{system.atk}}" min="0">
        {{/if}}
      </div>
    {{else if isBlackIceProgram}}
      {{!-- Black ICE programs don't carry their own REZ/ATK — the linked
           actor is the source of truth. The right column hosts the Actor
           Link input (UUID; accepts dragged Black-ICE actors from the
           sidebar). --}}
      <div class="variable-field">
        <label class="variable-label">{{localize "CYBERPUNK.NetwareActorLink"}}</label>
        <input type="text"
               class="variable-input"
               name="system.actorLink"
               value="{{system.actorLink}}"
               placeholder="{{localize "CYBERPUNK.NetwareActorLinkPlaceholder"}}"
               {{#if isLocked}}readonly{{/if}}>
      </div>
    {{else}}
      <div class="variable-field">
        <label class="variable-label">{{localize "CYBERPUNK.REZ"}}</label>
        {{#if isLocked}}
          <div class="dropdown"><span class="dropdown-text">{{system.rez}}</span></div>
        {{else}}
          <input type="number" class="variable-input" name="system.rez" value="{{system.rez}}" min="0">
        {{/if}}
      </div>
    {{/if}}
  </div>

  {{!-- Row 3: Divider — suppressed for Black ICE programs since no
       subtype-specific block follows; the linked actor sheet is the
       source of truth for Class / Damage / Effect. --}}
  {{#unless isBlackIceProgram}}
    <div class="divider"></div>
  {{/unless}}

  {{!-- ===================== --}}
  {{!-- BOOSTER               --}}
  {{!-- ===================== --}}
  {{#if isBooster}}
    {{!-- Row 4: Bonus + Value --}}
    <div class="variables-row">
      <div class="variable-field">
        <label class="variable-label">{{localize "CYBERPUNK.BoosterBonus"}}</label>
        {{#if isLocked}}
          <div class="dropdown">
            <span class="dropdown-text">{{selectedBoosterBonusLabel}}</span>
            <div class="dropdown-chevron">
              <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
            </div>
          </div>
        {{else}}
          <div class="dropdown-wrapper">
            <select class="dropdown-select" name="system.boosterBonus">
              {{#each boosterBonusOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <div class="dropdown-chevron">
              <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
            </div>
          </div>
        {{/if}}
      </div>

      <div class="variable-field">
        <label class="variable-label">{{localize "CYBERPUNK.BoosterValue"}}</label>
        {{#if isLocked}}
          <div class="dropdown"><span class="dropdown-text">{{system.boosterValue}}</span></div>
        {{else}}
          <input type="number" class="variable-input" name="system.boosterValue" value="{{system.boosterValue}}">
        {{/if}}
      </div>
    </div>
  {{/if}}

  {{!-- ===================== --}}
  {{!-- DEFENDER               --}}
  {{!-- ===================== --}}
  {{#if isDefender}}
    {{!-- Row 4: Defence + Value (only for Armor) --}}
    <div class="variables-row">
      <div class="variable-field">
        <label class="variable-label">{{localize "CYBERPUNK.DefenderDefence"}}</label>
        {{#if isLocked}}
          <div class="dropdown">
            <span class="dropdown-text">{{selectedDefenderDefenceLabel}}</span>
            <div class="dropdown-chevron">
              <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
            </div>
          </div>
        {{else}}
          <div class="dropdown-wrapper">
            <select class="dropdown-select" name="system.defenderDefence">
              {{#each defenderDefenceOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <div class="dropdown-chevron">
              <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
            </div>
          </div>
        {{/if}}
      </div>

      {{#if isArmorDefence}}
        <div class="variable-field">
          <label class="variable-label">{{localize "CYBERPUNK.DefenderValue"}}</label>
          {{#if isLocked}}
            <div class="dropdown"><span class="dropdown-text">{{system.defenderValue}}</span></div>
          {{else}}
            <input type="number" class="variable-input" name="system.defenderValue" value="{{system.defenderValue}}">
          {{/if}}
        </div>
      {{/if}}
    </div>
  {{/if}}

  {{!-- ===================== --}}
  {{!-- ATTACKER               --}}
  {{!-- ===================== --}}
  {{#if isAttacker}}
    {{!-- Row 4: Class + Damage --}}
    <div class="variables-row">
      <div class="variable-field">
        <label class="variable-label">{{localize "CYBERPUNK.AttackerClass"}}</label>
        {{#if isLocked}}
          <div class="dropdown">
            <span class="dropdown-text">{{selectedAttackerClassLabel}}</span>
            <div class="dropdown-chevron">
              <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
            </div>
          </div>
        {{else}}
          <div class="dropdown-wrapper">
            <select class="dropdown-select" name="system.attackerClass">
              {{#each attackerClassOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <div class="dropdown-chevron">
              <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
            </div>
          </div>
        {{/if}}
      </div>

      <div class="variable-field">
        <label class="variable-label">{{localize "CYBERPUNK.AttackerDamage"}}</label>
        {{#if isLocked}}
          <div class="dropdown"><span class="dropdown-text">{{system.attackerDamage}}</span></div>
        {{else}}
          <input type="text" class="variable-input" name="system.attackerDamage" value="{{system.attackerDamage}}">
        {{/if}}
      </div>
    </div>

    {{!-- Row 5: Effect --}}
    <div class="variables-row">
      <div class="variable-field">
        <label class="variable-label">{{localize "CYBERPUNK.AttackerEffect"}}</label>
        {{#if isLocked}}
          <div class="dropdown">
            <span class="dropdown-text">{{selectedAttackerEffectLabel}}</span>
            <div class="dropdown-chevron">
              <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
            </div>
          </div>
        {{else}}
          <div class="dropdown-wrapper">
            <select class="dropdown-select" name="system.attackerEffect">
              {{#each attackerEffectOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <div class="dropdown-chevron">
              <img src="systems/cyberpunk/img/ui/icon-down.svg" alt="">
            </div>
          </div>
        {{/if}}
      </div>
    </div>
  {{/if}}
{{/if}}
